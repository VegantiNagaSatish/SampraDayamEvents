rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /invoices/{invoiceId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
    match /catalogItems/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /eventSchedules/{scheduleId} {
      allow read, write: if request.auth != null;
    }
    /* Public food menu: anyone can read; only signed-in admins can edit */
    match /foodMenuSections/{sectionId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    
    /* Gallery images: anyone can read (for public gallery); only signed-in admins can write */
    match /images/{imageId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    
    /* Gallery categories: anyone can read; only signed-in admins can write */
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    
    /* Legacy gallery collections for backward compatibility */
    /* TEMPORARY: Allow public writes for testing (change to 'if request.auth != null' for production!) */
    match /galleryImages/{imageId} {
      allow read: if true;
      allow create, update, delete: if true; // TEMPORARY for testing
    }
    
    match /galleryCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if true; // TEMPORARY for testing
    }
  }
}
